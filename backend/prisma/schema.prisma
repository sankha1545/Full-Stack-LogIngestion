generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  MASTER_ADMIN
  USER
}

enum InquiryType {
  GENERAL
  PRICING
  ENTERPRISE
  INTEGRATIONS
  OTHER
}

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum AppMemberRole {
  OWNER
  ADMIN
  VIEWER
}

//////////////////////////////////////////////////////
// INDUSTRIAL LOG LEVELS
//////////////////////////////////////////////////////

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

//////////////////////////////////////////////////////
// AUTH EVENTS
//////////////////////////////////////////////////////

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  MFA_REQUIRED
  MFA_SUCCESS
  MFA_FAILED
  ACCOUNT_LOCKED
  MFA_SETUP_STARTED
  MFA_SETUP_COMPLETED
  MFA_DISABLED
  RECOVERY_CODE_USED
  RECOVERY_CODES_REGENERATED
  PASSWORD_RESET
  PASSWORD_CHANGED
  PASSWORD_VERIFY_SUCCESS
  PASSWORD_VERIFY_FAILED
  LOGOUT
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {

  id String @id @default(uuid())

  email String @unique

  username String @unique

  password String?

  role Role @default(USER)

  provider String @default("credentials")

  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt


  //////////////////////////////////////////////////////
  // SECURITY
  //////////////////////////////////////////////////////

  tokenVersion Int @default(0)

  passwordChangedAt DateTime?

  failedLoginAttempts Int @default(0)

  accountLockedUntil DateTime?


  //////////////////////////////////////////////////////
  // MFA
  //////////////////////////////////////////////////////

  mfaEnabled Boolean @default(false)

  mfaSecretEncrypted String?

  mfaFailedAttempts Int @default(0)

  mfaLockedUntil DateTime?


  //////////////////////////////////////////////////////
  // RELATIONS  ✅ REQUIRED
  //////////////////////////////////////////////////////

  profile UserProfile?

  contactRequests ContactRequest[]

  applications Application[]

  memberships AppMember[]

  authLogs AuthAuditLog[]

  refreshTokens RefreshToken[]

  recoveryCodes MfaRecoveryCode[]

  trustedDevices TrustedDevice[]

  alertRules AlertRule[]


  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////

  @@index([email])

  @@index([role])

  @@index([accountLockedUntil])

  @@index([mfaLockedUntil])

}

//////////////////////////////////////////////////////
// MFA RECOVERY CODES
//////////////////////////////////////////////////////

model MfaRecoveryCode {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeHash String
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([used])
}

//////////////////////////////////////////////////////
// TRUSTED DEVICES
//////////////////////////////////////////////////////

model TrustedDevice {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceHash String
  deviceName String?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([userId, deviceHash])
  @@index([userId])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// USER PROFILE
//////////////////////////////////////////////////////

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String?
  lastName    String?
  country     String?
  countryCode String?
  state       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// APPLICATION (CORE SAAS ENTITY)
//////////////////////////////////////////////////////

model Application {

  id String @id @default(uuid())

  name String

  environment Environment @default(DEVELOPMENT)

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectionUrl String?

  retentionDays Int @default(30)

  members AppMember[]

  apiKeys ApiKey[]

  logs Log[]

  metrics LogMetric[]

  //////////////////////////////////////////////////////
  // ✅ ADD THIS LINE
  //////////////////////////////////////////////////////

  alertRules AlertRule[]

  deleted Boolean @default(false)

  deletedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}

//////////////////////////////////////////////////////
// APP MEMBER
//////////////////////////////////////////////////////

model AppMember {
  id String @id @default(uuid())
  userId String
  applicationId String
  role AppMemberRole @default(VIEWER)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, applicationId])
  @@index([applicationId])
}

//////////////////////////////////////////////////////
// API KEYS
//////////////////////////////////////////////////////

model ApiKey {
  id String @id @default(uuid())
  name String?

  /**
   * Full hashed key stored securely
   */
  keyHash String @unique

  /**
   * partial key for UI display, example: ls_8f3a...91ab
   */
  keyPreview String?

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  rotatedAt DateTime?

  @@index([applicationId])
  @@index([revoked])
}

//////////////////////////////////////////////////////
// LOGS (CORE OBSERVABILITY MODEL)
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// LOGS (CORE OBSERVABILITY MODEL)
//////////////////////////////////////////////////////

model Log {

  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // TENANT
  //////////////////////////////////////////////////////

  applicationId String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)


  //////////////////////////////////////////////////////
  // CORE
  //////////////////////////////////////////////////////

  level LogLevel

  message String

  timestamp DateTime


  //////////////////////////////////////////////////////
  // TRACEABILITY
  //////////////////////////////////////////////////////

  resourceId String?

  traceId String?

  spanId String?

  commit String?


  //////////////////////////////////////////////////////
  // INDUSTRIAL FIELDS
  //////////////////////////////////////////////////////

  service String?

  environment Environment @default(DEVELOPMENT)

  host String?

  version String?

  tags String[] @default([])


  //////////////////////////////////////////////////////
  // FLEXIBLE METADATA
  //////////////////////////////////////////////////////

  metadata Json?


  //////////////////////////////////////////////////////
  // FULL TEXT SEARCH VECTOR
  //////////////////////////////////////////////////////

  searchVector Unsupported("tsvector")?


  //////////////////////////////////////////////////////
  // SYSTEM
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())


  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////

  @@index([applicationId])

  @@index([applicationId, timestamp])

  @@index([applicationId, level])

  @@index([service])

  @@index([environment])

  @@index([host])

  @@index([traceId])

  @@index([spanId])

}

//////////////////////////////////////////////////////
// ANALYTICS ENGINE
//////////////////////////////////////////////////////

model LogMetric {
  id String @id @default(uuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  timestamp DateTime

  errorCount Int @default(0)
  warnCount  Int @default(0)
  infoCount  Int @default(0)
  debugCount Int @default(0)

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([timestamp])
  @@index([applicationId, timestamp])
  @@unique([applicationId, timestamp])
}

//////////////////////////////////////////////////////
// CONTACT REQUEST
//////////////////////////////////////////////////////

model ContactRequest {
  id String @id @default(uuid())

  ref      String? @unique
  fullName String
  email    String

  phoneDialCode String?
  phoneLocal    String?
  phoneFull     String?

  company   String
  employees String?
  inquiry   InquiryType

  country String?
  state   String?

  message     String?
  marketingOk Boolean @default(false)

  source    String   @default("contact-sales-page")
  createdAt DateTime @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
}

//////////////////////////////////////////////////////
// ALERT RULE
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// ALERT RULE
//////////////////////////////////////////////////////

model AlertRule {

  id String @id @default(uuid())

  name String

  //////////////////////////////////////////////////////
  // RELATION IDS
  //////////////////////////////////////////////////////

  applicationId String

  userId String


  //////////////////////////////////////////////////////
  // CONDITIONS
  //////////////////////////////////////////////////////

  level LogLevel?

  query String?

  threshold Int

  windowMinutes Int @default(5)


  //////////////////////////////////////////////////////
  // ACTIONS
  //////////////////////////////////////////////////////

  email String?

  webhookUrl String?


  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  enabled Boolean @default(true)

  lastTriggered DateTime?


  //////////////////////////////////////////////////////
  // RELATIONS (FIXED — SAME LINE)
  //////////////////////////////////////////////////////

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)


  //////////////////////////////////////////////////////
  // TIMESTAMP
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())


  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////

  @@index([applicationId])

  @@index([userId])

  @@index([enabled])

}
//////////////////////////////////////////////////////
// EMAIL OTP
//////////////////////////////////////////////////////

model EmailOtp {
  id String @id @default(uuid())
  email String
  code String
  expiresAt DateTime
  verified Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// AUTH AUDIT LOG
//////////////////////////////////////////////////////

model AuthAuditLog {
  id String @id @default(uuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  email     String
  event     AuthEventType
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([event])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// REFRESH TOKEN
//////////////////////////////////////////////////////

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}